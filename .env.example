# Server-side Resend configuration (Vercel/Node runtime)
RESEND_API_KEY=your_resend_api_key
RESEND_TO_EMAIL=your_inbox@example.com
# Optional: verified sender on Resend (falls back to onboarding@resend.dev)
# RESEND_FROM_EMAIL=onboarding@resend.dev

# Optional frontend API base override (useful for local Vite dev):
# VITE_API_BASE_URL=http://localhost:3000
